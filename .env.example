# Sentinel-Remediator Configuration

# Server
SERVER_PORT=8080

# LLM Provider (anthropic or openai)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-20241022

# Anthropic API Key (required if using Anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI API Key (required if using OpenAI)
OPENAI_API_KEY=your-openai-api-key

# Qdrant Vector Database
QDRANT_URL=localhost:6334
QDRANT_API_KEY=
QDRANT_COLLECTION=sentinel_fixes

# GitHub Token (for creating PRs)
GITHUB_TOKEN=your-github-token

# Working Directory (for cloning repos)
WORK_DIR=/tmp/sentinel

# Agent Settings
MAX_ITERATIONS=10
MAX_TOKENS=4000
DRY_RUN=true # Set to false to allow git push and PR creation

# Logging
LOG_LEVEL=info
